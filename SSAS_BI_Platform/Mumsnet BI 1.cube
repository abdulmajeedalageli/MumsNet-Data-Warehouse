  <Source dwd:design-time-name="0dda8fb3-856a-4d1c-aaee-580e396daeac">
    <DataSourceViewID>Mumsnet BI 1</DataSourceViewID>
  </Source>
  <MdxScripts>
    <MdxScript dwd:design-time-name="c492dc75-dde7-4c15-93ed-3087eb5eab09">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE; 
CREATE MEMBER CURRENTCUBE.[Measures].[Total Cancelled]
 AS (
  [Measures].[Order Number Distinct Count],
  [DimStatus].[StatusHierarchy].&amp;[3]
), 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Unfufilled Out of Stock]
 AS (
  [Measures].[Order Number Distinct Count],
  [DimStatus].[StatusHierarchy].&amp;[2]
), 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Percentage Cancelled Sales Cost]
 AS IIF(
  [Measures].[Line Item Total] = 0,
  NULL,
  (
    [Measures].[Line Item Total],
    [DimStatus].[StatusHierarchy].&amp;[3]
  )
  /
  [Measures].[Line Item Total]
), 
FORMAT_STRING = "Percent", 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Sales Value Cancelled]
 AS (
    [Measures].[Line Item Total],
    [DimStatus].[StatusHierarchy].&amp;[3]
  ), 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Percentage Abandoned]
 AS (
  [Measures].[Order Number Distinct Count],
  [DimStatus].[StatusHierarchy].&amp;[1]
)
/
[Measures].[Order Number Distinct Count], 
FORMAT_STRING = "Percent", 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Percentage Fufilled]
 AS (
  [Measures].[Order Number Distinct Count],
  [DimStatus].[StatusHierarchy].&amp;[4]
)
/
[Measures].[Order Number Distinct Count], 
FORMAT_STRING = "Percent", 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Percentage Unfufilled]
 AS (
(
  [Measures].[Order Number Distinct Count],
  [DimStatus].[StatusHierarchy].&amp;[1]
)
+
(
  [Measures].[Order Number Distinct Count],
  [DimStatus].[StatusHierarchy].&amp;[2]
)
+
(
  [Measures].[Order Number Distinct Count],
  [DimStatus].[StatusHierarchy].&amp;[3]
)
)
/
[Measures].[Order Number Distinct Count], 
FORMAT_STRING = "Percent", 
VISIBLE = 1  ; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>